model ActionHistory {
  id Int @id @default(autoincrement())

  userName      String
  userDiscordId String

  req String
  res String

  usage   AiUsage? @relation(fields: [usageId], references: [id])
  usageId Int?     @unique

  aiCalls Int

  timeMs Int

  createdAt DateTime @default(now())

  @@map("action_history")
}
